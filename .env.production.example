# ==========================================
# PRODUCTION ENVIRONMENT VARIABLES
# Copy this to .env and fill in the values.
# ==========================================

# Security
SECRET_KEY=your-highly-secure-random-secret-key
DEBUG=False
DJANGO_ENV=production

# Hosts
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Database (PostgreSQL recommended for production)
# Format: postgres://USER:PASSWORD@HOST:PORT/NAME
DATABASE_URL=postgres://dbuser:dbpassword@dbhost:5432/dbname
# Or for local SQLite (default fallback): sqlite:///db.sqlite3

# Redis (Used for Django Channels and caching)
REDIS_URL=redis://redis:6379/1
# If deploying locally without Docker, use: redis://127.0.0.1:6379/1

# Optional: Email settings (for password reset, etc)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your_email@gmail.com
# EMAIL_HOST_PASSWORD=your_app_password
# EMAIL_USE_TLS=True
